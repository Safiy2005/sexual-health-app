<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sddp.sexualhealthapp.mainapp.controller.MainAppController"
           styleClass="main-app-root"
           prefWidth="360"
           prefHeight="640">

    <!-- Layer 1: Search View (articles list + search) -->
    <VBox fx:id="searchView" spacing="0">

        <!-- Header bar with title and lock button -->
        <HBox styleClass="search-header" alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets top="16" right="16" bottom="12" left="16"/>
            </padding>
            <Label text="Articles" styleClass="search-header-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Lock" styleClass="lock-button" onAction="#handleBackToCalculator"/>
        </HBox>

        <!-- Search bar -->
        <HBox styleClass="search-bar-container" alignment="CENTER">
            <padding>
                <Insets top="0" right="16" bottom="12" left="16"/>
            </padding>
            <TextField fx:id="searchField"
                       promptText="Search symptoms, conditions..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Results / articles list -->
        <ScrollPane fx:id="listScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                    styleClass="search-scroll-pane" hbarPolicy="NEVER">
            <VBox fx:id="articleListContainer" spacing="8" styleClass="article-list-container">
                <padding>
                    <Insets top="4" right="16" bottom="16" left="16"/>
                </padding>
                <!-- Article cards are added programmatically -->
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Layer 2: Article Detail View (hidden initially) -->
    <VBox fx:id="articleView" visible="false" styleClass="article-detail-root">

        <!-- Back bar with page counter -->
        <HBox styleClass="article-back-bar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="16" right="16" bottom="12" left="16"/>
            </padding>
            <Button text="Back" styleClass="article-back-button" onAction="#handleBackToSearch"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="pageCounterLabel" styleClass="page-counter-label"/>
        </HBox>

        <!-- Swipable article content area -->
        <StackPane fx:id="articlePageContainer" VBox.vgrow="ALWAYS"
                   styleClass="article-page-container">
            <!-- Pages are added programmatically -->
        </StackPane>

        <!-- Page indicator dots -->
        <HBox fx:id="pageIndicatorContainer" alignment="CENTER" spacing="8"
              styleClass="page-indicator-bar">
            <padding>
                <Insets top="10" right="16" bottom="16" left="16"/>
            </padding>
            <!-- Dots are added programmatically -->
        </HBox>
    </VBox>

</StackPane>
