<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sddp.sexualhealthapp.calendar.controller.EventFeedController"
      styleClass="calendar-root" spacing="0"
      prefWidth="360" prefHeight="640">

    <!-- Back navigation bar -->
    <HBox styleClass="calendar-header" alignment="CENTER_LEFT" spacing="10">
        <padding>
            <Insets top="16" right="16" bottom="12" left="16"/>
        </padding>
        <Button text="Back" styleClass="calendar-action-button"
                minWidth="-Infinity"
                onAction="#handleBackToCalendar"/>
        <Label text="Event Feed" styleClass="search-header-title"
               HBox.hgrow="ALWAYS" maxWidth="Infinity" wrapText="true"/>
        <Button text="Today" styleClass="calendar-today-button"
                minWidth="-Infinity"
                onAction="#handleJumpToToday"/>
    </HBox>

    <!-- Event type filter bar -->
    <HBox fx:id="filterBar" styleClass="event-feed-filter-bar" alignment="CENTER_LEFT" spacing="8">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16"/>
        </padding>
        <Button fx:id="filterAppointmentButton" text="Appointment" styleClass="event-feed-filter-chip"
                onAction="#handleFilterAppointment"/>
        <Button fx:id="filterMedicationButton" text="Medication" styleClass="event-feed-filter-chip"
                onAction="#handleFilterMedication"/>
        <Button fx:id="filterTestButton" text="Test" styleClass="event-feed-filter-chip"
                onAction="#handleFilterTest"/>
    </HBox>

    <!-- Upcoming events list (scrollable) -->
    <ScrollPane fx:id="feedScrollPane" fitToWidth="true"
                VBox.vgrow="ALWAYS" styleClass="search-scroll-pane"
                hbarPolicy="NEVER">
        <VBox fx:id="feedContainer" spacing="8"
              styleClass="calendar-day-events-container">
            <padding>
                <Insets top="8" right="16" bottom="16" left="16"/>
            </padding>
        </VBox>
    </ScrollPane>

</VBox>
