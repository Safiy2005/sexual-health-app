<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!-- Combined onboarding + setup carousel. Pages 0-2 are the tutorial,
     page 3 is the calculator setup. All slide within one StackPane. -->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sddp.sexualhealthapp.calculator.controller.SetupController"
           styleClass="onboarding-root"
           prefWidth="360" prefHeight="640">

    <!-- Onboarding Page 1: Protect your Privacy -->
    <VBox fx:id="onboardingPage1" styleClass="onboarding-page" alignment="TOP_CENTER" spacing="12">
        <padding>
            <Insets top="10" right="24" bottom="30" left="24"/>
        </padding>

        <Label text="Protect your Privacy" styleClass="onboarding-title" textAlignment="CENTER" wrapText="true"/>
        <Label text="Your app hides behind a working calculator."
               styleClass="onboarding-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER" prefWidth="312" maxWidth="312"/>

        <!-- Looping MP4 video / placeholder: shows calculator disguise concept -->
        <StackPane fx:id="videoContainer1" styleClass="onboarding-video-container" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="12"/>
            </VBox.margin>
            <!-- MediaView added programmatically by controller -->
            <VBox fx:id="videoPlaceholder1" styleClass="onboarding-video-placeholder" alignment="CENTER" spacing="4">
                <Label text="&#x1F4F1;" styleClass="onboarding-placeholder-icon"/>
                <Label text="calculator-disguise.mp4" styleClass="onboarding-placeholder-label"/>
            </VBox>
        </StackPane>

        <HBox alignment="CENTER" spacing="8">
            <Circle radius="4" styleClass="onboarding-dot-active"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
        </HBox>
        <Button text="Next" styleClass="onboarding-button" onAction="#handleOnboardingNext" alignment="CENTER">
        </Button>
    </VBox>

    <!-- Onboarding Page 2: Secret Equation -->
    <VBox fx:id="onboardingPage2" styleClass="onboarding-page" alignment="TOP_CENTER" spacing="12">
        <padding>
            <Insets top="10" right="24" bottom="30" left="24"/>
        </padding>

        <Label text="Secret Equation" styleClass="onboarding-title" textAlignment="CENTER" wrapText="true"/>
        <Label text="Create your own secret equation to unlock the app."
               styleClass="onboarding-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER" prefWidth="312" maxWidth="312"/>

        <!-- Looping MP4 video / placeholder: shows equation entry flow -->
        <StackPane fx:id="videoContainer2" styleClass="onboarding-video-container" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="12"/>
            </VBox.margin>
            <VBox fx:id="videoPlaceholder2" styleClass="onboarding-video-placeholder" alignment="CENTER" spacing="4">
                <Label text="&#x1F513;" styleClass="onboarding-placeholder-icon"/>
                <Label text="equation-unlock.mp4" styleClass="onboarding-placeholder-label"/>
            </VBox>
        </StackPane>

        <HBox alignment="CENTER" spacing="8">
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot-active"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
        </HBox>
        <Button text="Next" styleClass="onboarding-button" onAction="#handleOnboardingNext" alignment="CENTER">
        </Button>
    </VBox>

    <!-- Onboarding Page 3: Forgot Your Equation -->
    <VBox fx:id="onboardingPage3" styleClass="onboarding-page" alignment="TOP_CENTER" spacing="12">
        <padding>
            <Insets top="10" right="24" bottom="30" left="24"/>
        </padding>

        <Label text="Forgot Your Equation?" styleClass="onboarding-title" textAlignment="CENTER" wrapText="true" />
        <Label text="Use 999 &#xF7; 0 to reset your equation if you forget it."
               styleClass="onboarding-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER" prefWidth="312" maxWidth="312"/>

        <!-- Looping MP4 video / placeholder: shows reset code entry -->
        <StackPane fx:id="videoContainer3" styleClass="onboarding-video-container" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="12"/>
            </VBox.margin>
            <VBox fx:id="videoPlaceholder3" styleClass="onboarding-video-placeholder" alignment="CENTER" spacing="4">
                <Label text="&#x1F504;" styleClass="onboarding-placeholder-icon"/>
                <Label text="reset-code.mp4" styleClass="onboarding-placeholder-label"/>
            </VBox>
        </StackPane>

        <HBox alignment="CENTER" spacing="8">
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot-active"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
        </HBox>
        <Button text="Continue" styleClass="onboarding-button, onboarding-button-primary" onAction="#handleOnboardingContinue" alignment="CENTER">
        </Button>
    </VBox>

    <VBox fx:id="privacyPolicyPage" alignment="TOP_CENTER" spacing="16" styleClass="onboarding-page">
        <padding>
            <Insets top="10" right="24" bottom="30" left="24"/>
        </padding>

        <Label text="Your Privacy Matters" styleClass="onboarding-title"
               wrapText="true" textAlignment="CENTER" alignment="CENTER"
               prefWidth="312" maxWidth="312" minHeight="-Infinity"/>

        <Label text="Please read and agree to our core privacy principles before continuing."
               styleClass="onboarding-subtitle"
               wrapText="true" textAlignment="CENTER" alignment="CENTER"
               prefWidth="312" maxWidth="312" minHeight="-Infinity"/>

        <ScrollPane fx:id="privacyScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: #1C1C1E; -fx-padding: 0; -fx-border-color: transparent;">
            <VBox spacing="14">
                <padding>
                    <Insets bottom="20"/>
                </padding>

                <VBox styleClass="onboarding-example-box" spacing="8">
                    <Label text="Local Storage &amp; Data" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="All your data, including preferences and activity, is stored strictly locally on your device. It will never be uploaded, sold, or shared with external sources."
                           style="-fx-text-fill: #9AABAB; -fx-font-size: 13px; -fx-line-spacing: 2px;" wrapText="true"/>
                    <CheckBox fx:id="storageAgree" text="I understand" style="-fx-text-fill: white;"/>
                </VBox>

                <VBox fx:id="card2" styleClass="onboarding-example-box" spacing="8">
                    <Label text="Zero Analytics" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="We do not track your usage, monitor what articles you read, or collect behavioral data. There are no tracking scripts hidden in the background."
                           style="-fx-text-fill: #9AABAB; -fx-font-size: 13px; -fx-line-spacing: 2px;" wrapText="true"/>
                    <CheckBox fx:id="analyticsAgree" text="I understand" style="-fx-text-fill: white;"/>
                </VBox>

                <VBox fx:id="card3" styleClass="onboarding-example-box" spacing="8">
                    <Label text="Notifications &amp; Reminders" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="All reminders are generated directly on your device. You have full control over how they appear, including a disguised mode to protect your privacy."
                           style="-fx-text-fill: #9AABAB; -fx-font-size: 13px; -fx-line-spacing: 2px;" wrapText="true"/>
                    <CheckBox fx:id="notificationAgree" text="I understand" style="-fx-text-fill: white;"/>
                </VBox>

                <VBox fx:id="card4" styleClass="onboarding-example-box" spacing="8">
                    <Label text="Passcode Encryption" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Your passcode is securely encrypted. You can reset your passcode by entering 999/0 into the calculator disguise."
                           style="-fx-text-fill: #9AABAB; -fx-font-size: 13px; -fx-line-spacing: 2px;" wrapText="true"/>
                    <CheckBox fx:id="passcodeAgree" text="I understand" style="-fx-text-fill: white;"/>
                </VBox>

            </VBox>
        </ScrollPane>
        <HBox alignment="CENTER" spacing="8">
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot"/>
            <Circle radius="4" styleClass="onboarding-dot-active"/>
        </HBox>

        <Button fx:id="privacyContinueBtn" text="Agree &amp; Continue"
                styleClass="onboarding-button, onboarding-button-primary" onAction="#handleOnboardingNext"/>
    </VBox>

    <!-- Page 4: Calculator Setup -->
    <VBox fx:id="setupPage" styleClass="setup-root">

        <!-- Instruction Header (fixed at top) -->
        <VBox fx:id="instructionHeader" styleClass="instruction-header" alignment="CENTER" spacing="4">
            <Label fx:id="instructionTitle" styleClass="instruction-title" text="Create Your Secret Equation"/>
            <Label fx:id="instructionMessage" styleClass="instruction-message"
                   text="Enter an equation you'll remember"
                   wrapText="true" textAlignment="CENTER"/>
        </VBox>

        <!-- Calculator + Confirmation overlay -->
        <StackPane VBox.vgrow="ALWAYS">

            <!-- Calculator Interface -->
            <VBox styleClass="calculator-inner">
                <!-- Display Container (compact for setup) -->
                <HBox styleClass="display-container-compact">
                    <Label fx:id="displayLabel" styleClass="display" text="0"/>
                </HBox>

                <!-- Button Grid -->
                <GridPane styleClass="button-grid" VBox.vgrow="ALWAYS">
                    <!-- Row 0: Clear, Backspace, Divide, Multiply -->
                    <Button fx:id="clearButton" text="C" styleClass="calculator-button, clear-button"
                            onAction="#handleClear"
                            GridPane.columnIndex="0" GridPane.rowIndex="0"/>

                    <Button fx:id="backspaceButton" text="&#x232B;" styleClass="calculator-button, backspace-button"
                            onAction="#handleBackspace"
                            GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Button text="&#xF7;" styleClass="calculator-button, operation-button"
                            onAction="#handleOperation"
                            GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                    <Button text="&#xD7;" styleClass="calculator-button, operation-button"
                            onAction="#handleOperation"
                            GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                    <!-- Row 1: 7, 8, 9, - -->
                    <Button text="7" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Button text="8" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Button text="9" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                    <Button text="-" styleClass="calculator-button, operation-button"
                            onAction="#handleOperation"
                            GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                    <!-- Row 2: 4, 5, 6, + -->
                    <Button text="4" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="0" GridPane.rowIndex="2"/>

                    <Button text="5" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Button text="6" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                    <Button text="+" styleClass="calculator-button, operation-button"
                            onAction="#handleOperation"
                            GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                    <!-- Row 3: 1, 2, 3 -->
                    <Button text="1" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                    <Button text="2" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Button text="3" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="2" GridPane.rowIndex="3"/>

                    <!-- Equals button spans 2 rows -->
                    <Button fx:id="equalsButton" text="=" styleClass="calculator-button, equals-button"
                            onAction="#handleEquals"
                            GridPane.columnIndex="3" GridPane.rowIndex="3" GridPane.rowSpan="2"/>

                    <!-- Row 4: 0 (spans 2 columns), decimal point -->
                    <Button text="0" styleClass="calculator-button, number-button"
                            onAction="#handleNumber"
                            GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4"/>

                    <Button text="." styleClass="calculator-button, decimal-button"
                            onAction="#handleDecimal"
                            GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                </GridPane>
            </VBox>

            <!-- Confirmation Panel (overlays bottom when shown) -->
            <VBox fx:id="confirmationOverlay" alignment="BOTTOM_CENTER"
                  visible="false" managed="false" mouseTransparent="true">
                <VBox fx:id="confirmationPanel" styleClass="confirmation-panel"
                      alignment="CENTER" spacing="10">
                    <Label fx:id="equationPreview" styleClass="equation-preview" text="Your secret: 7+6=13"/>
                    <HBox alignment="CENTER" spacing="15">
                        <Button fx:id="confirmButton" text="Confirm" styleClass="confirm-button"
                                onAction="#handleConfirm"/>
                        <Button fx:id="retryButton" text="Try Again" styleClass="retry-button"
                                onAction="#handleRetry"/>
                    </HBox>
                </VBox>
            </VBox>

        </StackPane>
    </VBox>

</StackPane>
