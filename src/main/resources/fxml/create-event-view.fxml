<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sddp.sexualhealthapp.calendar.controller.CreateEventController"
      styleClass="calendar-root" spacing="0"
      prefWidth="360" prefHeight="640">

    <!-- Cancel navigation bar -->
    <HBox styleClass="calendar-header" alignment="CENTER_LEFT" spacing="10">
        <padding>
            <Insets top="16" right="16" bottom="12" left="16"/>
        </padding>
        <Button text="Cancel" styleClass="calendar-action-button"
                onAction="#handleBackToCalendar"/>
        <Label text="New Event" styleClass="search-header-title"
               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

    <!-- Placeholder content — TODO (Oli): stories 22.1-22.3 -->
    <VBox alignment="TOP_CENTER" spacing="16" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="30" right="24" bottom="30" left="24"/>
        </padding>

        <Label text="Create New Event" styleClass="calendar-selected-date-header"/>

        <VBox spacing="4" alignment="CENTER_LEFT">
            <Label text="Event Title"/>
            <TextField fx:id="titleField" promptText="E.g., Doctor Appointment"/>
        </VBox>

        <VBox spacing="4" alignment="CENTER_LEFT">
            <Label text="Date"/>
            <DatePicker fx:id="datePicker" promptText="Select a date" prefWidth="300"/>
        </VBox>

        <VBox spacing="4" alignment="CENTER_LEFT">
            <Label text="Event Type"/>
            <ComboBox fx:id="typeComboBox" promptText="Select category" prefWidth="300"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS" /> <Button text="Save Event" onAction="#handleSaveEvent" styleClass="calendar-action-button" prefWidth="300"/>

    </VBox>

</VBox>
