<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sddp.sexualhealthapp.calendar.controller.CreateEventController"
      styleClass="calendar-root"
      prefWidth="360" prefHeight="640">

    <HBox styleClass="calendar-header" alignment="CENTER_LEFT" spacing="10">
        <padding>
            <Insets top="16" right="16" bottom="12" left="16"/>
        </padding>
        <Button text="Cancel" styleClass="calendar-action-button"
                onAction="#handleBackToCalendar"/>
        <Label text="New Event" styleClass="search-header-title"
               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                styleClass="search-scroll-pane" hbarPolicy="NEVER">

        <VBox alignment="TOP_CENTER" spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="250" left="24"/>
            </padding>

            <Label text="Event Details" styleClass="calendar-selected-date-header"/>

            <VBox spacing="4" alignment="CENTER_LEFT">
                <HBox spacing="2">
                    <Label text="Event Title" styleClass="calendar-event-card-title"/>
                    <Label text="*" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                </HBox>
                <TextField fx:id="titleField" promptText="E.g. Doctors Appointment"
                           styleClass="search-field" prefWidth="300"/>
            </VBox>

            <VBox spacing="4" alignment="CENTER_LEFT">
                <HBox spacing="2">
                    <Label text="Date" styleClass="calendar-event-card-title"/>
                    <Label text="*" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                </HBox>
                <DatePicker fx:id="datePicker" promptText="Select a date dd/mm/yyy"
                            prefWidth="300" editable="false" styleClass="calendar-picker-combo"/>
            </VBox>

            <VBox spacing="4" alignment="CENTER_LEFT">
                <HBox spacing="2">
                    <Label text="Event Type" styleClass="calendar-event-card-title"/>
                    <Label text="*" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                </HBox>
                <ComboBox fx:id="typeComboBox" promptText="Select category"
                          prefWidth="300" styleClass="calendar-picker-combo"/>
            </VBox>
            <VBox fx:id="dosageContainer" spacing="4" alignment="CENTER_LEFT" visible="false" managed="false">
                <Label text="Dosage Amount" styleClass="calendar-event-card-title"/>
                <TextField fx:id="dosageField" promptText="E.g., 2 pills, 50mg"
                           prefWidth="300" styleClass="search-field"/>
            </VBox>



            <VBox spacing="4" alignment="CENTER_LEFT">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Time" styleClass="calendar-event-card-title"/>
                    <CheckBox fx:id="allDayCheckBox" text="All-day event" styleClass="calendar-event-card-time"/>
                </HBox>

                <HBox fx:id="timeSpinnerContainer" spacing="10" alignment="CENTER_LEFT">
                    <Spinner fx:id="hourSpinner" prefWidth="75" editable="true" styleClass="calendar-picker-combo"/>
                    <Label text=":" styleClass="calendar-event-card-title"/>
                    <Spinner fx:id="minuteSpinner" prefWidth="75" editable="true" styleClass="calendar-picker-combo"/>
                </HBox>
            </VBox>
            <VBox spacing="5">
                <Label text="Reminder" styleClass="calendar-event-card-title"/>
                <ComboBox fx:id="reminderComboBox" prefWidth="300" styleClass="calendar-picker-combo"/>
            </VBox>


            <VBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Repeat" styleClass="calendar-event-card-title"/>
                <ComboBox fx:id="recurrenceComboBox" prefWidth="300" styleClass="calendar-picker-combo"/>

                <HBox fx:id="intervalContainer" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
                    <padding><Insets top="4"/></padding>
                    <Label text="Repeat every" styleClass="calendar-event-card-time"/>
                    <Spinner fx:id="intervalSpinner" prefWidth="75" editable="true" styleClass="calendar-picker-combo"/>
                    <Label fx:id="intervalLabel" text="days" styleClass="calendar-event-card-time"/>
                </HBox>
            </VBox>
            <HBox fx:id="weeklyDaysContainer" spacing="6" visible="false" managed="false" alignment="CENTER_LEFT">
                <ToggleButton fx:id="btnMon" text="M" styleClass="day-toggle"/>
                <ToggleButton fx:id="btnTue" text="T" styleClass="day-toggle"/>
                <ToggleButton fx:id="btnWed" text="W" styleClass="day-toggle"/>
                <ToggleButton fx:id="btnThu" text="T" styleClass="day-toggle"/>
                <ToggleButton fx:id="btnFri" text="F" styleClass="day-toggle"/>
                <ToggleButton fx:id="btnSat" text="S" styleClass="day-toggle"/>
                <ToggleButton fx:id="btnSun" text="S" styleClass="day-toggle"/>
            </HBox>
            <Label fx:id="weeklySummaryLabel"
                   visible="false" managed="false" wrapText="true" maxWidth="300"
                   styleClass="calendar-event-card-time"/>

            <VBox fx:id="monthlyOptionsContainer" spacing="10" visible="false" managed="false">
                <RadioButton fx:id="radioSameDay" text="On the same day each month"
                             selected="true" styleClass="custom-radio"/>
                <RadioButton fx:id="radioNthWeekday" text="On the same weekday (e.g., 2nd Tue)"
                             styleClass="custom-radio"/>
                <RadioButton fx:id="radioLastDay" text="On the last day of the month"
                             styleClass="custom-radio"/>
            </VBox>

            <VBox fx:id="exceptionsContainer" spacing="5" visible="false" managed="false">
                <Label text="Exclude Dates (Optional)" styleClass="calendar-event-card-title"/>

                <HBox spacing="10" alignment="CENTER_LEFT">

                    <DatePicker fx:id="exceptionDatePicker" promptText="Select date..."
                                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                styleClass="calendar-picker-combo"/>

                    <Button text="Exclude" onAction="#handleAddException"
                            minWidth="85" styleClass="calendar-action-button-primary"/>

                </HBox>

                <ListView fx:id="exceptionListView" prefHeight="70" styleClass="search-field"/>
            </VBox>

            <VBox fx:id="endConditionContainer" spacing="4" alignment="CENTER_LEFT" visible="false" managed="false">
                <Label text="Ends" styleClass="calendar-event-card-title"/>

                <VBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="endTypeComboBox" prefWidth="300" styleClass="calendar-picker-combo"/>

                    <DatePicker fx:id="endDatePicker" prefWidth="300" visible="false" managed="false"
                                editable="false" promptText="End date" styleClass="calendar-picker-combo"/>

                    <HBox fx:id="occurrenceContainer" spacing="5" alignment="CENTER_LEFT" visible="false" managed="false">
                        <Spinner fx:id="occurrenceCountSpinner" prefWidth="75" editable="true" styleClass="calendar-picker-combo"/>
                        <Label text="times" styleClass="calendar-event-card-time"/>
                    </HBox>
                </VBox>
            </VBox>
            <VBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Description / Notes" styleClass="calendar-event-card-title"/>
                <TextArea fx:id="descriptionArea" promptText="Add any extra details here..."
                          prefRowCount="3" prefWidth="300" wrapText="true" styleClass="search-field"/>
            </VBox>


            <Region prefHeight="10"/>
            <Label fx:id="errorLabel" styleClass="error-label" visible="false" managed="false"/>

            <Button text="Save Event" onAction="#handleSaveEvent"
                    styleClass="calendar-action-button-primary" prefWidth="300" prefHeight="45"/>
            <Region prefHeight="20"/>

        </VBox>
    </ScrollPane>
</VBox>
