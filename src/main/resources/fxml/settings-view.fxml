<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sddp.sexualhealthapp.settings.controller.SettingsController"
      styleClass="settings-root"
      fillWidth="true">

    <VBox fx:id="settingsHomeView" spacing="0" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" styleClass="search-header">
            <padding>
                <Insets top="16" right="16" bottom="12" left="16"/>
            </padding>
            <Label text="Settings" styleClass="search-header-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>

        <ScrollPane fx:id="settingsHomeScrollPane" fitToWidth="true"  VBox.vgrow="ALWAYS"
                    hbarPolicy="NEVER">
            <VBox fx:id="settingsCardContainer" spacing="10" styleClass="settings-card-list">
                <padding>
                    <Insets top="4" right="16" bottom="16" left="16"/>
                </padding>
            </VBox>
        </ScrollPane>
    </VBox>

    <VBox fx:id="settingsDetailView" spacing="0" visible="false" managed="false" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" styleClass="article-back-bar">
            <padding>
                <Insets top="16" right="16" bottom="12" left="16"/>
            </padding>
            <Button text="Back" styleClass="article-back-button" onAction="#handleBackToSettingsHome"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="settingsDetailTitle" styleClass="settings-detail-title"/>
        </HBox>

        <ScrollPane fx:id="settingsDetailScrollPane" fitToWidth="true"  VBox.vgrow="ALWAYS"
                    hbarPolicy="NEVER">
            <VBox fx:id="settingsDetailContent" spacing="14">
                <padding>
                    <Insets top="4" right="16" bottom="16" left="16"/>
                </padding>
            </VBox>
        </ScrollPane>
    </VBox>
</VBox>
