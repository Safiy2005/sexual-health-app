<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sddp.sexualhealthapp.article.controller.ArticleViewController"
      visible="false" styleClass="article-detail-root">

    <!-- Back bar with page counter -->
    <HBox styleClass="article-back-bar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="16" right="16" bottom="12" left="16"/>
        </padding>
        <Button text="Back" styleClass="article-back-button" onAction="#handleBack"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="pageCounterLabel" styleClass="page-counter-label"/>
    </HBox>

    <!-- Swipable article content area -->
    <StackPane fx:id="articlePageContainer" VBox.vgrow="ALWAYS"
               styleClass="article-page-container">
        <!-- Pages are added programmatically -->
    </StackPane>

    <!-- Page indicator dots -->
    <HBox fx:id="pageIndicatorContainer" alignment="CENTER" spacing="8"
          styleClass="page-indicator-bar">
        <padding>
            <Insets top="10" right="16" bottom="16" left="16"/>
        </padding>
        <!-- Dots are added programmatically -->
    </HBox>

</VBox>
